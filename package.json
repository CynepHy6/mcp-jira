{
    "name": "mcp-atlas",
    "version": "1.4.0",
    "description": "MCP server for Jira, Confluence, Insight (Assets), and Zephyr Scale",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CynepHy6/mcp-atlas.git"
    },
    "bugs": {
        "url": "https://github.com/CynepHy6/mcp-atlas/issues"
    },
    "homepage": "https://github.com/CynepHy6/mcp-atlas#readme",
    "main": "build/index.js",
    "type": "module",
    "bin": {
        "mcp-atlas": "./build/index.js"
    },
    "scripts": {
        "compile": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
        "prepublishOnly": "npm run compile",
        "start": "node ./build/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "files": [
        "build",
        "LICENSE"
    ],
    "keywords": [
        "mcp",
        "jira",
        "confluence",
        "atlassian",
        "cursor",
        "npx",
        "zephyr"
    ],
    "author": "",
    "license": "ISC",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^22.10.0",
        "jest": "^29.5.0",
        "nock": "^13.3.0",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.2"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.4.0",
        "axios": "^1.11.0",
        "dotenv": "^16.4.7",
        "jira.js": "^5.2.2",
        "zod": "^3.24.2"
    }
}
