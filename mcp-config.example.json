{
    "mcpServers": {
        "jira": {
            "command": "npx",
            "args": ["-y", "github:CynepHy6/mcp-jira#dist"],
            "env": {
                "JIRA_HOST": "https://jira.yourcompany.com",
                "JIRA_USERNAME": "your_login",
                "JIRA_API_TOKEN": "your_jira_personal_access_token",
                "CONFLUENCE_HOST": "https://confluence.yourcompany.com",
                "CONFLUENCE_USERNAME": "your_login",
                "CONFLUENCE_API_TOKEN": "your_confluence_personal_access_token"
            }
        }
    }
}
